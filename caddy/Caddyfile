# Caddy reverse proxy for Ghost.
#
# The site address comes from CADDY_SITE_ADDRESS (set in .env, passed through
# docker-compose.yml):
#   - local testing (default): ":80" — plain HTTP, visit http://localhost/
#   - production: your domain, e.g. "blog.example.com" — Caddy automatically
#     obtains & renews a Let's Encrypt certificate (ports 80/443 must be open).
{$CADDY_SITE_ADDRESS::80} {
	reverse_proxy ghost:2368

	encode gzip zstd

	log {
		output stdout
		format console
	}
}
