# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is git-ignored so secrets never get committed.

# Public URL Ghost is served on.
#   Local testing:        http://localhost
#   Production (IP only): http://203.0.113.10
#   Production (domain):  https://blog.example.com (must match CADDY_SITE_ADDRESS)
GHOST_URL=http://localhost

# Caddy site address. Leave unset (defaults to ":80", plain HTTP) for local
# testing or an IP-only production server. Once you have a domain, set it
# (no scheme), e.g. blog.example.com — Caddy then serves HTTPS with an
# automatic Let's Encrypt certificate.
#CADDY_SITE_ADDRESS=blog.example.com

# MySQL credentials — CHANGE THESE before any real deployment.
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=change-me-ghost-password

# Umami analytics (web UI on port 8080).
# The `umami` MySQL database and user must be created once by hand:
#   CREATE DATABASE umami CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   CREATE USER 'umami'@'%' IDENTIFIED WITH mysql_native_password BY '<UMAMI_DB_PASSWORD>';
#   GRANT ALL PRIVILEGES ON umami.* TO 'umami'@'%';
# APP_SECRET signs sessions — any long random string (e.g. `openssl rand -hex 32`).
UMAMI_DB_PASSWORD=change-me-umami-db-password
UMAMI_APP_SECRET=change-me-long-random-string
