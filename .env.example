# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is git-ignored so secrets never get committed.

# Public URL Ghost is served on. Local testing: http://localhost
# Production: https://blog.example.com (must match the Caddyfile site address).
GHOST_URL=http://localhost

# MySQL credentials — CHANGE THESE before any real deployment.
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=change-me-ghost-password
